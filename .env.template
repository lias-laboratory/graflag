# GraFlag Configuration File
# Copy this to .env and customize for your environment

# Manager Connection (Required)
# The IP address of the manager node as seen by this machine
MANAGER_IP=192.168.100.10

# SSH Configuration (Optional)
# SSH port for connecting to the manager
SSH_PORT=22

# SSH private key file for authentication (required)
SSH_KEY=~/.ssh/my_ssh_key

# NFS Configuration (Optional)
# NFS port for mounting shared storage
NFS_PORT=2049

# Remote NFS directory
SHARED_DIR=/shared

# Default Settings
DEFAULT_TAG=latest
DEFAULT_BUILD=false